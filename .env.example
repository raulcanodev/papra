# Mandatory
APP_BASE_URL=https://tu-dominio.com
AUTH_SECRET=  # genera con: openssl rand -hex 48

# Database (por defecto SQLite local, descomenta para usar PostgreSQL)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Registro de nuevos usuarios (desactívalo tras crear tu cuenta)
AUTH_IS_REGISTRATION_ENABLED=true

# Almacenamiento de documentos: filesystem (default), s3, azure
DOCUMENT_STORAGE_DRIVER=

# Cloudflare R2 (o cualquier S3-compatible) — solo si DOCUMENT_STORAGE_DRIVER=s3
DOCUMENT_STORAGE_S3_ACCESS_KEY_ID=
DOCUMENT_STORAGE_S3_SECRET_ACCESS_KEY=
DOCUMENT_STORAGE_S3_BUCKET_NAME=
DOCUMENT_STORAGE_S3_REGION=auto
DOCUMENT_STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# DOCUMENT_STORAGE_S3_FORCE_PATH_STYLE=false  # activa para MinIO

# Cifrado de documentos (AES-256-GCM) — funciona con cualquier driver
# Genera la clave con: openssl rand -hex 32
DOCUMENT_STORAGE_ENCRYPTION_IS_ENABLED=false
DOCUMENT_STORAGE_DOCUMENT_KEY_ENCRYPTION_KEYS=  # clave hex de 64 caracteres — NO LA PIERDAS

# Emails: logger (sin envío), smtp, resend
EMAILS_DRIVER=

# AI Assistant (opcional)
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
